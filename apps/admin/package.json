{
  "name": "admin",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "system:migration:create": "npx mikro-orm migration:create",
    "system:migration:create:initial": "npx mikro-orm migration:create --initial",
    "system:migration:up": "npx mikro-orm migration:up",
    "system:migration:down": "npx mikro-orm migration:down",
    "system:migration:list": "npx mikro-orm migration:list",
    "system:migration:pending": "npx mikro-orm migration:pending",
    "system:migration:fresh": "npx mikro-orm migration:fresh",
    "system:schema:create": "npx mikro-orm schema:create",
    "system:schema:drop": "npx mikro-orm schema:drop --run",
    "system:schema:update": "npx mikro-orm schema:update",
    "system:schema:fresh": "npx mikro-orm schema:fresh",
    "system:schema:fresh:run": "npx mikro-orm schema:fresh --run",
    "system:schema:fresh:drop": "npx mikro-orm schema:fresh --run --drop-db",
    "system:seeder:run": "npx mikro-orm seeder:run",
    "system:seeder:create": "npx mikro-orm seeder:create",
    "system:db:fresh": "npx mikro-orm schema:fresh --run-migrations && npx mikro-orm seeder:run",
    "system:cache:clear": "npx mikro-orm cache:clear"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.6",
    "@mikro-orm/migrations": "^6.6.6",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/reflection": "^6.6.6",
    "@mikro-orm/seeder": "^6.6.6",
    "@mikro-orm/sql-highlighter": "^1.0.1",
    "@mikro-orm/sqlite": "^6.6.6",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "express-request-id": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@mikro-orm/cli": "^6.6.6",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
