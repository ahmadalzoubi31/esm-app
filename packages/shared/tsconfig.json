{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",     // Compatible with both Vite (bundler) and NestJS (via paths)
    "lib": ["ES2022", "DOM"],
    "declaration": true,               // Generates .d.ts (required for composite)
    "declarationMap": true,            // "Go to Definition" jumps to .ts source, not .d.ts
    "sourceMap": true,
    "strict": true,                    // Full strictness ensures breakage propagates
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,                 // Required for TypeScript project references
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}